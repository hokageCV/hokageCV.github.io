---
import { getBlogList } from '@/utils/collection'
import BlogListCard from './BlogListCard.astro'
import type { CollectionEntry } from 'astro:content'

type Props = {
  count?: number
  basePath?: string
  blogPostList?: CollectionEntry<'blogs' | 'drafts'>[]
}

const { count, basePath, blogPostList } = Astro.props
const blogList = blogPostList ||  await getBlogList()

if (count) blogList.splice(count)
---

<section>
  <ul>
    {blogList.map((post) => <BlogListCard {post} {basePath} />)}
  </ul>
</section>
