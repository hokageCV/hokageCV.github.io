---
import { readableDate } from '@/utils/date'

const { post } = Astro.props
const url = `/blogs/${post.id}`
---

<li>
    <div>
      <small>{readableDate(post.data.published_date, 'dd-LL-yyyy')}</small>
      <span class="favorite-star">{post.data.favorite ? '★' : '\u00A0'}</span>
      <a href={url}>{post.data.title}</a>
    </div>
</li>

<style>
  li {
    list-style: none;
    margin-bottom: var(--space-xs);

    div {
      display: flex;
      flex-direction: row;
      justify-content: flex-start;
      align-items: baseline;
      gap: var(--space-xs);

      small {
        font-size: var(--step--2);
        color: grey;
        flex-shrink: 0;
      }

      .favorite-star {
        color: #f5a623;
        flex-shrink: 0;
        width: 1em;
        text-align: center;
      }

      a {
        text-decoration: none;
      }
    }
  }

  @media (max-width: 600px) {
    li div {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;

      small {
        font-size: var(--step--3);
      }
    }
  }
</style>
