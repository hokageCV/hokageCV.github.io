---
import { getTilIndexList } from '@/utils/collection'
import { render } from 'astro:content'

const til_list = await getTilIndexList()
---

<section>
  {
    await Promise.all(
      til_list.map(async (post) => {
        const { Content } = await render(post)
        const is_blog = post.collection === 'blogs'
        const href = is_blog ? `/blogs/${post.id}` : `/til/${post.id}`

        return (
          <div class='card'>
            <a href={href} class='title'>
              {post.data.title}
            </a>

            <div class='til-date'>
              {new Date(post.data.published_date).toLocaleDateString('en-US', {
                day: '2-digit',
                month: 'short',
                year: 'numeric',
              })}
            </div>

            <div class='body'>
              <Content />
            </div>
          </div>
        )
      }),
    )
  }
</section>

<style>
  section {
    width: 75%;
    max-width: 80%;
    display: flex;
    justify-content: center;
    flex-direction: column;

    margin-bottom: var(--space-l);

    .card {
      border: 2px solid;
      border-radius: var(--space-2xs);

      padding: var(--space-xs);
      margin: var(--space-xs);

      width: max-content;
      max-width: 90%;

      .title {
        font-size: var(--step-2);
      }

      .body {
        margin-top: var(--space-s);
      }
    }
  }
</style>
