---
import { getExcerpt } from '@/utils/excerpt'
const { project, index } = Astro.props
const url = `/projects/${project.id}`
const excerpt = getExcerpt(project.body)
---

<article class='featured-card'>
  <a href={url} class='media-col' aria-label={`Open ${project.data.title}`}>
    {
      project.data.cover.image ? (
        <img src={project.data.cover.image} alt={project.data.cover.alt} class='media' />
      ) : (
        <video src={project.data.cover.video} autoplay loop muted playsinline class='media' />
      )
    }
  </a>

  <div class='text-col'>
    <h3 class='title'>
      <a href={url}>{project.data.title}</a>
    </h3>

    {excerpt && <p class='excerpt'>{excerpt}</p>}

    <div class='links'>
      {
        project.data.repo_link && (
          <a href={project.data.repo_link} target='_blank' rel='noreferrer' class='link'>
            Source Code
          </a>
        )
      }
      {
        project.data.live_link && (
          <a href={project.data.live_link} target='_blank' rel='noreferrer' class='link'>
            Live Link
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .featured-card {
    display: grid;
    grid-template-columns: 2fr 1fr;
    align-items: stretch;
    gap: var(--space-s);
    margin: var(--space-s) var(--space-xs);
    padding: var(--space-m);
    height: 440px;

    background: color-mix(in srgb, var(--base-background) 75%, var(--secondary-color) 25%);
    border: 1px solid color-mix(in srgb, var(--secondary-color) 50%, var(--accent) 50%);

    border-radius: 18px;
    box-shadow: var(--project-card-shadow);
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .featured-card:nth-child(even) {
    grid-template-columns: 1fr 2fr;
  }
  .featured-card:nth-child(even) .media-col {
    order: 2;
  }
  .featured-card:nth-child(even) .text-col {
    order: 1;
  }

  .media-col {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--secondary-color) 65%);
    background: color-mix(in srgb, var(--secondary-color) 35%, transparent);
    text-decoration: none;
  }

  .media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .text-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: 0.25rem;
    min-width: 0;
    align-self: stretch;
  }

  .title {
    margin: 0;
    line-height: 1;
  }
  .title a {
    color: var(--page-heading-color);
    text-decoration: none;
    font-size: var(--step-2);
    font-family: var(--mono-font);
    text-transform: uppercase;
    letter-spacing: 0.045em;
  }

  .excerpt {
    margin: 0;
    color: var(--base-text);
    opacity: 0.76;
    font-size: var(--step-0);
    line-height: 1.55;
  }

  .links {
    display: flex;
    gap: var(--space-m);
    margin-top: auto;
    padding-top: var(--space-xs);
    border-top: 1px solid color-mix(in srgb, var(--secondary-color) 85%, var(--accent) 15%);
  }

  .link {
    font-family: var(--mono-font);
    font-size: var(--step--2);
    letter-spacing: 0.1em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.2rem;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }
  .link:hover {
    border-bottom-color: var(--accent);
    transform: translateX(2px);
  }

  @media (max-width: 900px) {
    .featured-card,
    .featured-card:nth-child(even) {
      grid-template-columns: 1fr;
      grid-template-rows: auto 240px 1fr;
      height: auto;
      min-height: 480px;
      margin: var(--space-s) var(--space-m);
    }
    .featured-card:nth-child(even) .media-col,
    .featured-card:nth-child(even) .text-col {
      order: unset;
    }
  }
</style>
