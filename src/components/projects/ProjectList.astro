---
import { getProjectList } from '@/utils/collection'
import ProjectCard from './ProjectCard.astro'

const projects = await getProjectList()
const archived_projects = await getProjectList({ archived: true })
---

<div class='projects-container'>
  <section class='projects-grid'>
    {projects.map((project) => <ProjectCard {project} />)}
  </section>

  <details>
    <summary> Archived Projects </summary>
    <div class='archived-grid'>
      {archived_projects.map((project) => <ProjectCard {project} />)}
    </div>
  </details>
</div>

<style>
  .projects-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-m);

    .projects-grid,
    .archived-grid {
      width: 100%;
      max-width: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    details {
      width: 100%;
      margin-bottom: var(--space-2xl);
      padding: 0;

      summary {
        text-align: center;
        cursor: pointer;
        font-size: var(--step-2);
      }
    }
  }
</style>
