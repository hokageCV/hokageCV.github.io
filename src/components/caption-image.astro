---
import { Image } from "astro:assets"

interface Props {
  src: any
  alt: string
  caption?: string
  credit?: string
}

const { src, alt, caption, credit } = Astro.props
---

<figure>
  <Image src={src} alt={alt} title={alt} />
  {caption && <figcaption>{caption}{credit && <><br /><small>{credit}</small></>}</figcaption>}
</figure>
