---
import Project from '@/components/projects/Project.astro'
import Base from '@/layouts/Base.astro'
import { getProjectList } from '@/utils/collection'
import { render } from 'astro:content'

export async function getStaticPaths() {
  const project_list = await getProjectList({ all: true })
  const paths = await Promise.all(project_list.map(async (project) => {
    const { Content } = await render(project)
    return {
      params: { slug: project.id },
      props: { project, Content },
    }
  }))
  return paths
}

const { project, Content } = Astro.props
const { data } = project
---

<Base title={data.title}>
  <Project data={data} Content={Content} />
</Base>
